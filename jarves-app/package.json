{
  "name": "jarves-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "concurrently \"npm:fast-vite\" \"npm:electron:dev\"",
    "fast-vite": "vite",
    "electron:dev": "electron --loader ts-node/esm ./electron/main.ts",
    "start": "electron --loader ts-node/esm ./electron/main.ts",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "electron": "^26.2.0",
    "ts-node": "^10.9.1"
  }
}
